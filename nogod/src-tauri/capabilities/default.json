{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "$HOME/**",
          "recursive": true
        }
      ],
      "deny": []
    },
    {
      "identifier": "fs:read-dirs",
      "allow": [
        {
          "path": "$HOME/**",
          "recursive": true
        }
      ],
      "deny": []
    },
    {
      "identifier": "fs:read-files",
      "allow": [
        {
          "path": "$HOME/**",
          "recursive": true
        }
      ],
      "deny": []
    },
    {
      "identifier": "fs:write-files",
      "allow": [
        {
          "path": "$HOME/**",
          "recursive": true
        }
      ],
      "deny": []
    }
  ]
}